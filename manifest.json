{
  "manifest_version": 3,
  "name": "7D: 7TV & Discord",
  "version": "0.0.1",
  "action": { "default_popup": "index.html" },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://*.discord.com/*",
    "https://7tv.io/*",
    "https://api.betterttv.net/*"
  ],
  "content_scripts": [
    {
      "js": ["src/main.ts"],
      "matches": ["https://*.discord.com/*"]
    }
  ]
}