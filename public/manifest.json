{
  "name": "7D - 7TV Emotes for Discord",
  "short_name": "7D Emotes",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },  
  "manifest_version": 3,
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "js": ["main.js"],
      "matches": ["https://*.discord.com/*"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.discord.com/*",
    "https://cdn.7tv.app/*",
    "https://7tv.io/*",
    "https://api.ivr.fi/*"
  ]
}