{
  "manifest_version": 3,
  "name": "7D: 7TV & Discord",
  "version": "0.0.1",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["main.js"],
      "matches": ["https://*.discord.com/*"]
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://*.discord.com/*",
    "https://cdn.7tv.app/*"
  ]
}