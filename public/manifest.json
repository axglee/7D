{
  "name": "7D: 7TV Emotes for Discord",
  "short_name": "7D Emotes",
  "manifest_version": 3,
  "version": "0.0.1",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["main.js"],
      "matches": ["https://*.discord.com/*"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.discord.com/*",
    "https://cdn.7tv.app/*",
    "https://7tv.io/*",
    "https://api.ivr.fi/*"
  ]
}